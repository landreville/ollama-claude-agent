# syntax=docker/dockerfile:1
# Development image — mounts source code for live reload.
# Usage:
#   docker build -f Dockerfile-dev -t ollama-claude-agent-dev .
#   docker run -d --name ollama-claude-dev \
#     -p 11434:11434 \
#     -e OLLAMA_CLAUDE_API_KEY=your-secret-api-key \
#     -v $(pwd)/src:/app/src \
#     -v $(pwd)/pyproject.toml:/app/pyproject.toml \
#     -v ~/.claude/.credentials.json:/home/appuser/.claude/.credentials.json:ro \
#     ollama-claude-agent-dev

FROM python:3.12-slim

# Install Node.js (required for Claude CLI) and other dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Install Claude CLI globally
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

# Pre-install dependencies as a cache layer. src/ is copied so hatchling can
# resolve the package metadata; the volume mount will overlay it at runtime.
COPY pyproject.toml README.md ./
COPY src/ src/
RUN pip install --no-cache-dir -e ".[dev]"

COPY entrypoint-dev.sh /entrypoint-dev.sh

RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
RUN chmod +x /entrypoint-dev.sh
RUN mkdir -p /home/appuser/.claude && chown -R appuser:appuser /home/appuser/.claude

USER appuser

EXPOSE 11434

ENV OLLAMA_CLAUDE_HOST=0.0.0.0
ENV OLLAMA_CLAUDE_PORT=11434

# PYTHONPATH makes ollama_claude importable directly from the mounted src/,
# independent of editable-install .pth mechanics and appuser write permissions.
ENV PYTHONPATH=/app/src

ENTRYPOINT ["/entrypoint-dev.sh"]
